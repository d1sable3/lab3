#include <iostream>
using namespace std;

// Базовий абстрактний клас - бінарна логічна функція
class LogicFunction
{
public:
    LogicFunction() {}
    virtual bool Calculation(bool x, bool y) = 0;
    virtual const char* Name() = 0;
    virtual ~LogicFunction() {}
};

// Кон'юнкція
class And : public LogicFunction
{
public:
    And() : LogicFunction() {}
    bool Calculation(bool x, bool y) override { return x && y; }
    const char* Name() override { return "AND"; }
};

// Диз'юнкція
class Or : public LogicFunction
{
public:
    Or() : LogicFunction() {}
    bool Calculation(bool x, bool y) override { return x || y; }
    const char* Name() override { return "OR"; }
};

// Виключне АБО
class Xor : public LogicFunction
{
public:
    Xor() : LogicFunction() {}
    bool Calculation(bool x, bool y) override { return x != y; }
    const char* Name() override { return "XOR"; }
};

// Штрих Шеффера (І-НЕ)
class Nand : public LogicFunction
{
public:
    Nand() : LogicFunction() {}
    bool Calculation(bool x, bool y) override { return !(x && y); }
    const char* Name() override { return "NAND"; }
};

// Вузол односвязного списку
struct Element
{
    LogicFunction* item;
    Element* next;
};

// Клас-контейнер з динамічним списком об'єктів
class Container
{
private:
    Element* first;

public:
    Container()
    {
        first = nullptr;
    }

    ~Container()
    {
        Element* temp = first;
        while (temp != nullptr)
        {
            Element* next = temp->next;
            delete temp->item;
            delete temp;
            temp = next;
        }
    }

    // Додавання нового елемента у початок списку
    void Add(LogicFunction* p)
    {
        Element* temp = new Element;
        temp->item = p;
        temp->next = first;
        first = temp;
    }

    // Виведення результату кожної функції для заданих аргументів (поліморфізм)
    void PrintAll(bool x, bool y)
    {
        Element* temp = first;
        while (temp != nullptr)
        {
            cout << temp->item->Name() << "(" << x << ", " << y << ") = "
                 << temp->item->Calculation(x, y) << endl;
            temp = temp->next;
        }
    }

    // Ключова функціональність: значення логічного виразу,
    // у якому між усіма функціями стоїть операція &
    bool EvaluateExpression(bool x, bool y)
    {
        if (first == nullptr)
            return false;

        bool result = true;
        Element* temp = first;
        while (temp != nullptr)
        {
            result = result && temp->item->Calculation(x, y);
            temp = temp->next;
        }
        return result;
    }
};

int main()
{
    Container container;
    container.Add(new And);
    container.Add(new Or);
    container.Add(new Xor);
    container.Add(new Nand);

    bool x = 1;
    bool y = 0;

    cout << "Aргументи: x = " << x << ", y = " << y << endl << endl;

    cout << "Результати окремих функцій:" << endl;
    container.PrintAll(x, y);

    cout << endl;
    cout << "Значення виразу (всі функції через &): "
         << container.EvaluateExpression(x, y) << endl;

    return 0;
}
