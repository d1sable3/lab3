// ==================== НАТИВНІ КЛАСИ (логіка з ПЗ №3) ====================

// Базовий абстрактний клас - бінарна логічна функція
class LogicFunction
{
public:
    LogicFunction() {}
    virtual bool Calculation(bool x, bool y) = 0;
    virtual const char* Name() = 0;
    virtual ~LogicFunction() {}
};

// Кон'юнкція
class And : public LogicFunction
{
public:
    bool Calculation(bool x, bool y) override { return x && y; }
    const char* Name() override { return "AND"; }
};

// Диз'юнкція
class Or : public LogicFunction
{
public:
    bool Calculation(bool x, bool y) override { return x || y; }
    const char* Name() override { return "OR"; }
};

// Виключне АБО
class Xor : public LogicFunction
{
public:
    bool Calculation(bool x, bool y) override { return x != y; }
    const char* Name() override { return "XOR"; }
};

// Штрих Шеффера (І-НЕ)
class Nand : public LogicFunction
{
public:
    bool Calculation(bool x, bool y) override { return !(x && y); }
    const char* Name() override { return "NAND"; }
};

// Вузол однозв'язного списку
struct Element
{
    LogicFunction* item;
    Element* next;
};

// Клас-контейнер з динамічним списком об'єктів
class Container
{
private:
    Element* first;

public:
    Container() { first = nullptr; }

    ~Container()
    {
        Element* temp = first;
        while (temp != nullptr)
        {
            Element* next = temp->next;
            delete temp->item;
            delete temp;
            temp = next;
        }
    }

    void Add(LogicFunction* p)
    {
        Element* node = new Element;
        node->item = p;
        node->next = nullptr;
        if (first == nullptr) { first = node; return; }
        Element* temp = first;
        while (temp->next != nullptr) temp = temp->next;
        temp->next = node;
    }

    int Count()
    {
        int c = 0;
        for (Element* t = first; t != nullptr; t = t->next) c++;
        return c;
    }

    LogicFunction* GetAt(int index)
    {
        Element* temp = first;
        int i = 0;
        while (temp != nullptr)
        {
            if (i == index) return temp->item;
            temp = temp->next; i++;
        }
        return nullptr;
    }

    // Ключова функціональність: значення виразу через операцію &
    bool EvaluateExpression(bool x, bool y)
    {
        if (first == nullptr) return false;
        bool result = true;
        Element* temp = first;
        while (temp != nullptr)
        {
            result = result && temp->item->Calculation(x, y);
            temp = temp->next;
        }
        return result;
    }
};

